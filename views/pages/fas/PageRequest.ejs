<script>

    function loadView() {
        loadingShow();
        setTimeout(() => {
            loadingHide();

            formDataSet(
                'FormView',
                {
                    RequestDate: '2026-05-01',
                    RequestCost: '$500.00',
                    Branch: 'PRIVILEGE-3',
                    Requester: 'PRIVILEGE-5',
                    Narrative: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit.'
                }
            );

            $('#popup-form-view').modal('show');
        }, 1000);
    }

    function loadEdit() {
        loadingShow();
        setTimeout(() => {
            loadingHide();

            formDataSet(
                'FormEdit',
                {
                    RequestDate: '2026-05-01',
                    RequestCost: '$500.00',
                    Branch: 'PRIVILEGE-3',
                    Requester: 'PRIVILEGE-5',
                    Narrative: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit.'
                }
            );

            $('#popup-form-edit').modal('show');
        }, 1000);
    }

    function submitCreate() {
        loadingShow();
        setTimeout(() => {
            loadingHide();
            
            const formData = {
                RequestDate: $('#FormCreate-RequestDate').val(),
                RequestCost: $('#FormCreate-RequestCost').val(),
                Branch: $('#FormCreate-Branch').val(),
                Requester: $('#FormCreate-Requester').val(),
                Narrative: $('#FormCreate-Narrative').val()
            };

            formDataClean('FormCreate');

            $('#popup-form-create').modal('hide');
        }, 1000);
    }

    function submitEdit() {
        loadingShow();
        setTimeout(() => {
            loadingHide();

            const formData = {
                RequestDate: $('#FormEdit-RequestDate').val(),
                RequestCost: $('#FormEdit-RequestCost').val(),
                Branch: $('#FormEdit-Branch').val(),
                Requester: $('#FormEdit-Requester').val(),
                Narrative: $('#FormEdit-Narrative').val()
            };

            formDataClean('FormEdit');

            $('#popup-form-edit').modal('hide');
        }, 1000);
    }

    function formDataClean(formId) {

        $('#'+ formId +'-RequestDate').val('');
        $('#'+ formId +'-Narrative').val('');
        $('#'+ formId +'-RequestCost').val('');

        const Branch = window.choicesInstances?.[formId +'-Branch'];
        const Requester = window.choicesInstances?.[formId +'-Requester'];

        if (Branch) {
            Branch.setChoiceByValue([]);
        } else {
            $('#'+ formId +'-accountType').val([]);
        }
        if (Requester) {
            Requester.setChoiceByValue([]);
        } else {
            $('#'+ formId +'-accountType').val([]);
        }

    }

    function formDataSet(formId, data) {
        $('#'+ formId +'-RequestDate').val(data.RequestDate);
        $('#'+ formId +'-Narrative').val(data.Narrative);
        $('#'+ formId +'-RequestCost').val(data.RequestCost);

        const Branch = window.choicesInstances?.[formId +'-Branch'];
        const Requester = window.choicesInstances?.[formId +'-Requester'];

        if (Branch) {
            Branch.setChoiceByValue(data.Branch);
        } else {
            $('#'+ formId +'-accountType').val(data.Branch);
        }
        if (Requester) {
            Requester.setChoiceByValue(data.Requester);
        } else {
            $('#'+ formId +'-accountType').val(data.Requester);
        }
    }

</script>
