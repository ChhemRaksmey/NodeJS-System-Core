                    <th class="py-1 bg-primary text-white col-2 text-center">Request Date</th>
                    <th class="py-1 bg-primary text-white col-2 text-end">Request Cost</th>
                    <th class="py-1 bg-primary text-white col-7">Narrative</th>
                    <th class="py-1 bg-primary text-white col-1 text-center">Action</th>
                </tr>
            </thead>

            <tbody>

                <% Array(23).fill().map((_, row) => { %>
                    <tr>
                        <td class="py-1 text-center">2026-05-<%= (row + 1).toString().padStart(2, '0') %></td>
                        <td class="py-1 text-end">$<%= (Math.random() * 1000).toFixed(2) %></td>
                        <td class="py-1">Lorem ipsum dolor sit amet, consectetur adipiscing elit.</td>
                        <td class="py-1 text-center">
                            <div class="dropdown">
                                <button class="btn btn-sm btn-primary pt-1 pb-0" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="icon dripicons dripicons-dots-3"></i>
                                </button>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item text-sm" onclick="loadView()"> <%= __('button.btnView') %></a></li>
                                    <li><hr class="my-1" /></li>
                                    <li><a class="dropdown-item text-sm" onclick="loadEdit()"> <%= __('button.btnEdit') %></a></li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                <% }) %>

            </tbody>

        </table>
    </div>
</div>

